{
  "info": {
    "_postman_id": "health-portal-group-c-2026",
    "name": "Health Portal API — Wire-Speed Demons (Group C)",
    "description": "Run order for a clean demonstration:\n\n  1. Auth > Login                          → sets {{token}} automatically\n  2. Patients > Create Patient              → sets {{testPatientId}}\n  3. Vaccinations > Create Vaccination (Future)  → isDue = false\n  4. Vaccinations > Create Vaccination (Due)     → isDue = true\n  5. Patients > Get Patient (has schedule link)  → HATEOAS demo\n  6. Appointments > Book Appointment        → sets {{testAppointmentId}}\n  7. Run the rest in order — cleanup is at the very bottom.\n\nSeeded IDs (pre-populated in collection variables):\n  seededPatientId  = b2c3d4e5-0000-0000-0000-000000000001  (Jane Doe)\n  seededClinicId   = a1b2c3d4-0000-0000-0000-000000000001  (Baltimore Clinic)\n  slotDate         = 2026-05-15",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },

  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },

  "variable": [
    { "key": "baseUrl",          "value": "http://localhost:8080/api/v1", "type": "string" },
    { "key": "token",            "value": "", "type": "string" },
    { "key": "testPatientId",    "value": "", "type": "string" },
    { "key": "testVaccinationId","value": "", "type": "string" },
    { "key": "testAppointmentId","value": "", "type": "string" },
    { "key": "seededPatientId",  "value": "b2c3d4e5-0000-0000-0000-000000000001", "type": "string" },
    { "key": "seededClinicId",   "value": "a1b2c3d4-0000-0000-0000-000000000001", "type": "string" },
    { "key": "slotDate",         "value": "2026-05-15", "type": "string" }
  ],

  "item": [

    {
      "name": "1 · Auth",
      "item": [
        {
          "name": "Login → sets token",
          "auth": { "type": "noauth" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('Token returned', () => pm.expect(json.token).to.be.a('string'));",
            "pm.collectionVariables.set('token', json.token);",
            "console.log('Token saved:', json.token.substring(0, 30) + '...');"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login — 401 Wrong Credentials",
          "auth": { "type": "noauth" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"wrongpassword\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Protected endpoint — 401 No Token",
          "auth": { "type": "noauth" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 401 without token', () => pm.response.to.have.status(401));",
            "pm.test('Error message present', () => pm.expect(pm.response.json().error).to.be.a('string'));"
          ]}}],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/patients", "host": ["{{baseUrl}}"], "path": ["patients"] }
          }
        }
      ]
    },

    {
      "name": "2 · Patients",
      "item": [
        {
          "name": "List Patients",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('Has content array', () => pm.expect(json.content).to.be.an('array'));",
            "pm.test('Has page metadata', () => pm.expect(json.page).to.be.an('object'));",
            "pm.test('Has _links', () => pm.expect(json._links).to.be.an('object'));",
            "pm.test('At least 2 seeded patients', () => pm.expect(json.content.length).to.be.at.least(2));",
            "pm.test('id field comes before _links', () => {",
            "  const keys = Object.keys(json.content[0]);",
            "  pm.expect(keys.indexOf('id')).to.be.lessThan(keys.indexOf('_links'));",
            "});"
          ]}}],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/patients?page=0&size=20", "host": ["{{baseUrl}}"], "path": ["patients"],
              "query": [{ "key": "page", "value": "0" }, { "key": "size", "value": "20" }] }
          }
        },
        {
          "name": "Create Patient → sets testPatientId",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const json = pm.response.json();",
            "pm.test('Has id', () => pm.expect(json.id).to.be.a('string'));",
            "pm.test('Has _links', () => pm.expect(json._links).to.be.an('object'));",
            "pm.test('Has self link', () => pm.expect(json._links.self).to.be.an('object'));",
            "pm.test('Has vaccinations link', () => pm.expect(json._links.vaccinations).to.be.an('object'));",
            "pm.test('No schedule link (no due vaccinations yet)', () => pm.expect(json._links.schedule).to.be.undefined);",
            "pm.collectionVariables.set('testPatientId', json.id);",
            "console.log('testPatientId set to', json.id);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Alex\",\n  \"lastName\": \"Demo\",\n  \"dateOfBirth\": \"1995-03-20\",\n  \"email\": \"alex.demo@example.com\",\n  \"phone\": \"410-555-1234\",\n  \"address\": {\n    \"street\": \"100 Test Ave\",\n    \"city\": \"Baltimore\",\n    \"state\": \"MD\",\n    \"zip\": \"21201\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/patients", "host": ["{{baseUrl}}"], "path": ["patients"] }
          }
        },
        {
          "name": "Create Patient — 409 Duplicate Email",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 409 Conflict', () => pm.response.to.have.status(409));",
            "pm.test('Error shape valid', () => {",
            "  const json = pm.response.json();",
            "  pm.expect(json.status).to.eql(409);",
            "  pm.expect(json.message).to.be.a('string');",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Duplicate\",\n  \"lastName\": \"User\",\n  \"dateOfBirth\": \"1990-01-01\",\n  \"email\": \"alex.demo@example.com\",\n  \"phone\": \"410-000-0000\",\n  \"address\": {\n    \"street\": \"999 Other St\",\n    \"city\": \"Baltimore\",\n    \"state\": \"MD\",\n    \"zip\": \"21201\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/patients", "host": ["{{baseUrl}}"], "path": ["patients"] }
          }
        },
        {
          "name": "Create Patient — 400 Validation Error",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));",
            "pm.test('Error shape valid', () => {",
            "  const json = pm.response.json();",
            "  pm.expect(json.status).to.eql(400);",
            "  pm.expect(json.message).to.be.a('string');",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"\",\n  \"email\": \"not-an-email\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/patients", "host": ["{{baseUrl}}"], "path": ["patients"] }
          }
        },
        {
          "name": "Get Patient (no schedule link yet)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('ID matches', () => pm.expect(json.id).to.eql(pm.collectionVariables.get('testPatientId')));",
            "pm.test('Has self link', () => pm.expect(json._links.self).to.be.an('object'));",
            "pm.test('Has vaccinations link', () => pm.expect(json._links.vaccinations).to.be.an('object'));",
            "pm.test('Has appointments link', () => pm.expect(json._links.appointments).to.be.an('object'));",
            "pm.test('No schedule link (no due vaccinations)', () => pm.expect(json._links.schedule).to.be.undefined);"
          ]}}],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/patients/{{testPatientId}}", "host": ["{{baseUrl}}"], "path": ["patients", "{{testPatientId}}"] }
          }
        },
        {
          "name": "Get Patient — 404 Not Found",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 404', () => pm.response.to.have.status(404));",
            "pm.test('Error shape valid', () => {",
            "  const json = pm.response.json();",
            "  pm.expect(json.status).to.eql(404);",
            "  pm.expect(json.message).to.be.a('string');",
            "});"
          ]}}],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/patients/00000000-0000-0000-0000-000000000000", "host": ["{{baseUrl}}"], "path": ["patients", "00000000-0000-0000-0000-000000000000"] }
          }
        },
        {
          "name": "Update Patient",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Phone updated', () => pm.expect(pm.response.json().phone).to.eql('410-555-9999'));"
          ]}}],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Alex\",\n  \"lastName\": \"Demo\",\n  \"dateOfBirth\": \"1995-03-20\",\n  \"email\": \"alex.demo@example.com\",\n  \"phone\": \"410-555-9999\",\n  \"address\": {\n    \"street\": \"100 Test Ave\",\n    \"city\": \"Baltimore\",\n    \"state\": \"MD\",\n    \"zip\": \"21201\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/patients/{{testPatientId}}", "host": ["{{baseUrl}}"], "path": ["patients", "{{testPatientId}}"] }
          }
        },
        {
          "name": "Get Seeded Patient (Jane Doe)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('First name correct', () => pm.expect(json.firstName).to.eql('Jane'));",
            "pm.test('Has address', () => pm.expect(json.address).to.be.an('object'));"
          ]}}],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/patients/{{seededPatientId}}", "host": ["{{baseUrl}}"], "path": ["patients", "{{seededPatientId}}"] }
          }
        }
      ]
    },

